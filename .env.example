# Copie este arquivo para .env e preencha os valores

NODE_ENV=development
PORT=3001

# Banco de dados (Docker local: veja docker-compose.yml)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/musa_dev"

# JWT — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=substitua_por_string_aleatoria_de_64_chars
JWT_EXPIRES_IN=7d

# URL do frontend (usada nos links de email)
FRONTEND_URL=http://localhost:5173

# Supabase Storage (upload de fotos — pode deixar vazio em dev local)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=musa-avatars

# Resend (emails transacionais — pode deixar vazio em dev, link aparece no console)
RESEND_API_KEY=
CONTACT_TO_EMAIL=contato@musacasa.com.br

# Stripe (pagamentos — pode deixar vazio em dev)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# CORS — separar múltiplas origens por vírgula
CORS_ORIGIN=http://localhost:5173
